{
  "name": "cyoa-editor",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "generate-types": "json2ts -i src/schema/CYOA_Schema.json -o src/types/adventure.generated.ts --no-additionalProperties",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test --pass-with-no-tests"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^24.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
